# Azure Storage (optional - for cloud upload of splat files)
# Leave AZURE_UPLOAD_ENABLED=false for local-only mode (default, free)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_storage_account;AccountKey=your_account_key;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=splats
AZURE_UPLOAD_ENABLED=false

# RTMP Configuration (local inference)
# Stream URL where drone video is ingested for real-time processing
RTMP_URL=rtmp://localhost:1935/live/drone

# Output Configuration
# Local directory where .ply/.splat files are written
OUTPUT_DIR=output/splats
